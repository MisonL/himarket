# HiMarket Docker 部署配置
# 复制到用户目录并按需修改: cp .env.example ~/himarket-install.env
# install.sh 会自动加载 ~/himarket-install.env

# ========== 部署模式 ==========
# install = 首次安装, upgrade = 升级已有部署, reinstall = 清空重装（脚本也会自动检测）
DEPLOY_MODE=install

# ========== 镜像配置 ==========
HIMARKET_SERVER_IMAGE=opensource-registry.cn-hangzhou.cr.aliyuncs.com/higress-group/himarket-server:latest
HIMARKET_ADMIN_IMAGE=opensource-registry.cn-hangzhou.cr.aliyuncs.com/higress-group/himarket-admin:latest
HIMARKET_FRONTEND_IMAGE=opensource-registry.cn-hangzhou.cr.aliyuncs.com/higress-group/himarket-frontend:latest
MYSQL_IMAGE=opensource-registry.cn-hangzhou.cr.aliyuncs.com/higress-group/mysql:latest
NACOS_IMAGE=nacos-registry.cn-hangzhou.cr.aliyuncs.com/nacos/nacos-server:v3.2.0-BETA
HIGRESS_IMAGE=higress-registry.cn-hangzhou.cr.aliyuncs.com/higress/all-in-one:latest
REDIS_IMAGE=higress-registry.cn-hangzhou.cr.aliyuncs.com/higress/redis-stack-server:7.4.0-v3
SANDBOX_IMAGE=opensource-registry.cn-hangzhou.cr.aliyuncs.com/higress-group/sandbox:latest

# ========== 数据库密码 ==========
# 必须固定，否则重装时本地数据与新密码不匹配
MYSQL_ROOT_PASSWORD=himarket_root_2024
MYSQL_PASSWORD=himarket_app_2024

# ========== 服务凭证 ==========
NACOS_ADMIN_PASSWORD=nacos
HIGRESS_USERNAME=admin
HIGRESS_PASSWORD=admin

# ========== 默认用户 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
FRONT_USERNAME=user
FRONT_PASSWORD=123456

# ========== 初始化选项 ==========
SKIP_MCP_INIT=false
SKIP_SKILL_INIT=false

# ========== AI 模型配置（可选）==========
SKIP_AI_MODEL_INIT=true
AI_MODEL_COUNT=0
# 取消下方注释并填写 API Key 即可启用 AI 模型
# SKIP_AI_MODEL_INIT=false
# AI_MODEL_COUNT=1
# AI_MODEL_1_PROVIDER=qwen
# AI_MODEL_1_TYPE=qwen
# AI_MODEL_1_DOMAIN=dashscope.aliyuncs.com
# AI_MODEL_1_PORT=443
# AI_MODEL_1_PROTOCOL=
# AI_MODEL_1_API_KEY=your-api-key-here
# AI_MODEL_1_NAME="Alibaba Cloud Qwen"
# ========== 管理端 CAS 认证配置 (联调验收版) ==========
# [何时设置]: 当你需要通过企业 SSO 统一管理后台登录时
ADMIN_AUTH_CAS_CONFIGS_0_PROVIDER=cas
# [何时设置]: 必填。UI 按钮上显示的文字
ADMIN_AUTH_CAS_CONFIGS_0_NAME="企业级统一身份认证"
# [何时设置]: 必填。是否启用此认证源
ADMIN_AUTH_CAS_CONFIGS_0_ENABLED=true
# [何时设置]: 必填。CAS 服务器的根地址。系统会自动推导登录、校验等路径
ADMIN_AUTH_CAS_CONFIGS_0_SERVER_URL=https://sso.example.com/cas
# [何时设置]: 必填。认证成功后跳回的地址，通常是管理端域名
ADMIN_AUTH_CAS_CONFIGS_0_FRONTEND_REDIRECT_URL=http://localhost:5174

# --- 身份映射 (决定 JWT 载荷内容) ---
# [何时设置]: 当你需要指定特定属性作为 HiMarket 用户 ID 时 (默认: user)
ADMIN_AUTH_CAS_CONFIGS_0_IDENTITY_MAPPING_USER_ID_FIELD=user
# [何时设置]: 当你希望同步 CAS 里的邮箱到 HiMarket 个人资料时
ADMIN_AUTH_CAS_CONFIGS_0_IDENTITY_MAPPING_EMAIL_FIELD=mail
# [何时设置]: 当你希望同步 CAS 里的真实姓名到头像旁时
ADMIN_AUTH_CAS_CONFIGS_0_IDENTITY_MAPPING_DISPLAY_NAME_FIELD=displayName

# --- 高级协议设置 ---
# [何时设置]: 仅当默认的 CAS3 协议无法握手时手动指定 (可选: SAML1, CAS1, CAS2, CAS3)
ADMIN_AUTH_CAS_CONFIGS_0_VALIDATION_PROTOCOL_VERSION=CAS3
# [何时设置]: 仅当 CAS 服务器只支持 JSON 响应时指定 (默认: XML)
ADMIN_AUTH_CAS_CONFIGS_0_VALIDATION_RESPONSE_FORMAT=XML

# --- 登录行为控制 ---
# [何时设置]: 设为 true 则每次进入都必须在 CAS 重新输入密码，不信任 CAS 已有 Session
ADMIN_AUTH_CAS_CONFIGS_0_LOGIN_RENEW=false
# [何时设置]: 开启单点登出。如果你希望在 HiMarket 退出后，CAS 也同步登出，请设为 true
ADMIN_AUTH_CAS_CONFIGS_0_SLO_ENABLED=true
